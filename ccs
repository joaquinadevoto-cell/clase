/* Dispositivo 1: Celular (Base) */
body {
    background-color: lightcoral; /* Un color para móvil */
    font-family: sans-serif;
    transition: background-color 0.3s ease; /* Para que el cambio sea suave */
}

.texto-columnas {
    column-count: 1;
    padding: 20px;
}
@media (min-width: 768px) {
    body {
        background-color: lightblue; /* Cambia el color */
    }

    .texto-columnas {
        column-count: 2; /* Cambia a 2 columnas */
        column-gap: 30px; /* Espacio entre columnas */
    }
}
@media (min-width: 1024px) {
    body {
        background-color: lightgreen; /* Tercer color */
    }

    .texto-columnas {
        column-count: 3; /* Cambia a 3 columnas */
        column-gap: 40px;
    }
}
